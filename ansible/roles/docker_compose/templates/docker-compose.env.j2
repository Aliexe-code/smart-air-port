# Environment variables for Docker Compose
# Generated by Ansible on {{ ansible_date_time.iso8601 }}

# Application configuration
BUILD_NUMBER={{ build_number | default('latest') }}
HOST_IP={{ ansible_host }}
ENVIRONMENT={{ environment | default('production') }}

# Django configuration
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,{{ ansible_host }}
DJANGO_TRUSTED_ORIGIN=http://localhost,http://{{ ansible_host }}

# Port configuration
APP_PORT={{ app_port | default(8000) }}
NGINX_PORT={{ nginx_port | default(80) }}

# Docker image configuration
WEB_IMAGE=nouraldeen152/networkapp:{{ build_number | default('latest') }}
NGINX_IMAGE=nginx:latest

# Volume configuration
STATIC_FILES_VOLUME=staticfiles

# Network configuration
NETWORK_NAME=app_network
